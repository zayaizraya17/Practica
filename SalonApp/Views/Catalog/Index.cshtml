@model IEnumerable<SalonApp.Models.Product>

@{
    ViewData["Title"] = "Каталог товаров";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><span class="me-2">📱</span>Каталог товаров</h1>
    <a asp-action="Create" class="btn btn-primary btn-lg">
        <span class="me-2">➕</span>Добавить товар
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info d-flex align-items-center">
        <span class="me-2 fs-4">ℹ️</span>
        <div>
            <strong>Каталог пуст.</strong> Добавьте первый товар, чтобы начать работу!
        </div>
    </div>
}
else
{
    <div class="card-custom p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Название</th>
                        <th>Тип</th>
                        <th>Цена (₽)</th>
                        <th>Остаток</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@product.Id</span></td>
                            <td class="fw-semibold">@product.Name</td>
                            <td>
                                <span class="badge @(product.Type == "телефон" ? "bg-primary" : "bg-secondary")">
                                    @(product.Type == "телефон" ? "📱" : "🎧") @product.Type
                                </span>
                            </td>
                            <td class="fw-bold text-primary">@product.Price.ToString("N0") ₽</td>
                            <td>
                                <span class="badge @(product.Stock > 0 ? "bg-success" : "bg-danger")">
                                    @(product.Stock > 0 ? "✓" : "✗") @product.Stock шт.
                                </span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning">
                                        <span class="me-1">✏️</span>Изменить
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-danger">
                                        <span class="me-1">🗑️</span>Удалить
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-3 text-muted">
        <small>📊 Всего товаров: @Model.Count()</small>
    </div>
}
