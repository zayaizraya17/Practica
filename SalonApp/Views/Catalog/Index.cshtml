@model IEnumerable<SalonApp.Models.Product>

@{
    ViewData["Title"] = "Каталог товаров";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>📱 Каталог товаров</h1>
    <a asp-action="Create" class="btn btn-primary">+ Добавить товар</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Каталог пуст. Добавьте первый товар!
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Тип</th>
                <th>Цена (₽)</th>
                <th>Остаток</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>@product.Name</td>
                    <td>
                        <span class="badge @(product.Type == "телефон" ? "bg-primary" : "bg-secondary")">
                            @product.Type
                        </span>
                    </td>
                    <td>@product.Price.ToString("N0")</td>
                    <td>
                        <span class="badge @(product.Stock > 0 ? "bg-success" : "bg-danger")">
                            @product.Stock шт.
                        </span>
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Изменить</a>
                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-danger">Удалить</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
