@model SalonApp.Models.Product

@{
    ViewData["Title"] = "Редактировать товар";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><span class="me-2">✏️</span>Редактировать товар</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <span class="me-2">↩️</span>Назад к каталогу
    </a>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card-custom">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-4">
                    <label asp-for="Name" class="form-label">📝 Название товара</label>
                    <input asp-for="Name" class="form-control form-control-lg" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                
                <div class="mb-4">
                    <label asp-for="Type" class="form-label">🏷️ Тип товара</label>
                    <select asp-for="Type" class="form-select form-select-lg">
                        <option value="">-- Выберите тип --</option>
                        <option value="телефон">📱 Телефон</option>
                        <option value="аксессуар">🎧 Аксессуар</option>
                    </select>
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label asp-for="Price" class="form-label">💰 Цена (₽)</label>
                        <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    
                    <div class="col-md-6 mb-4">
                        <label asp-for="Stock" class="form-label">📦 Остаток на складе (шт.)</label>
                        <input asp-for="Stock" type="number" class="form-control form-control-lg" />
                        <span asp-validation-for="Stock" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a asp-action="Index" class="btn btn-secondary btn-lg me-md-2">
                        <span class="me-2">❌</span>Отмена
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg">
                        <span class="me-2">💾</span>Сохранить изменения
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card-custom">
            <h5 class="mb-3">ℹ️ Информация</h5>
            <div class="alert alert-info mb-3">
                <strong>Редактирование:</strong>
                <p class="mb-0 mt-2">Внесите изменения в поля формы и нажмите "Сохранить изменения".</p>
            </div>
            
            <div class="bg-light p-3 rounded">
                <h6 class="mb-2">📋 Текущие данные</h6>
                <p class="mb-1"><strong>ID:</strong> @Model.Id</p>
                <p class="mb-1"><strong>Товар:</strong> @Model.Name</p>
                <p class="mb-0"><strong>Тип:</strong> @(Model.Type == "телефон" ? "📱" : "🎧") @Model.Type</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
