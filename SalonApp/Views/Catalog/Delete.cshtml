@model SalonApp.Models.Product

@{
    ViewData["Title"] = "Удалить товар";
}

<h1>🗑️ Удалить товар</h1>
<hr />

<div class="alert alert-warning">
    <h4>Вы уверены, что хотите удалить этот товар?</h4>
</div>

<div>
    <dl class="row">
        <dt class="col-sm-3">Название</dt>
        <dd class="col-sm-9">@Model.Name</dd>
        
        <dt class="col-sm-3">Тип</dt>
        <dd class="col-sm-9">@Model.Type</dd>
        
        <dt class="col-sm-3">Цена</dt>
        <dd class="col-sm-9">@Model.Price.ToString("N0") ₽</dd>
        
        <dt class="col-sm-3">Остаток</dt>
        <dd class="col-sm-9">@Model.Stock шт.</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">🗑️ Удалить</button>
        <a asp-action="Index" class="btn btn-secondary">↩️ Отмена</a>
    </form>
</div>
