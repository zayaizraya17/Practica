@model SalonApp.Models.Product

@{
    ViewData["Title"] = "Добавить товар";
}

<h1>➕ Добавить товар</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Название товара</label>
                <input asp-for="Name" class="form-control" placeholder="Например: iPhone 15" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Type" class="form-label">Тип товара</label>
                <select asp-for="Type" class="form-select">
                    <option value="">-- Выберите тип --</option>
                    <option value="телефон">Телефон</option>
                    <option value="аксессуар">Аксессуар</option>
                </select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Price" class="form-label">Цена (₽)</label>
                <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Stock" class="form-label">Остаток на складе (шт.)</label>
                <input asp-for="Stock" type="number" class="form-control" placeholder="0" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>
            
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">💾 Сохранить</button>
                <a asp-action="Index" class="btn btn-secondary">↩️ Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
