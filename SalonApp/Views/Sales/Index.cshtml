@model IEnumerable<SalonApp.Models.Sale>

@{
    ViewData["Title"] = "Журнал продаж";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><span class="me-2">📊</span>Журнал продаж</h1>
    <a asp-action="Create" class="btn btn-success btn-lg">
        <span class="me-2">➕</span>Новая продажа
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center">
        <span class="me-2 fs-4">✅</span>
        <div>@TempData["SuccessMessage"]</div>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info d-flex align-items-center">
        <span class="me-2 fs-4">ℹ️</span>
        <div>
            <strong>Продаж пока нет.</strong> Оформите первую продажу!
        </div>
    </div>
}
else
{
    <div class="card-custom p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>№</th>
                        <th>Дата</th>
                        <th>Товар</th>
                        <th>Количество</th>
                        <th>Сумма (₽)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sale in Model)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@sale.Id</span></td>
                            <td><i class="bi bi-calendar"></i> @sale.Date.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-semibold">📦 @sale.ProductName</td>
                            <td><span class="badge bg-primary">@sale.Quantity шт.</span></td>
                            <td class="fw-bold text-success">💰 @sale.Total.ToString("N0") ₽</td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end"><strong>📈 Всего продаж:</strong></td>
                        <td class="fw-bold text-primary fs-5">💵 @Model.Sum(s => s.Total).ToString("N0") ₽</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    
    <div class="mt-3 d-flex gap-2">
        <a asp-action="Create" class="btn btn-success">
            <span class="me-2">➕</span>Новая продажа
        </a>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">
            <span class="me-2">📱</span>Каталог товаров
        </a>
    </div>
}
