@model IEnumerable<SalonApp.Models.Sale>

@{
    ViewData["Title"] = "Журнал продаж";
}

<h1>📋 Журнал продаж</h1>
<hr />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Продаж пока нет. Оформите первую продажу!
    </div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>№</th>
                <th>Дата</th>
                <th>Товар</th>
                <th>Количество</th>
                <th>Сумма (₽)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var sale in Model)
            {
                <tr>
                    <td>@sale.Id</td>
                    <td>@sale.Date.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@sale.ProductName</td>
                    <td>@sale.Quantity шт.</td>
                    <td class="fw-bold">@sale.Total.ToString("N0")</td>
                </tr>
            }
        </tbody>
        <tfoot class="table-light">
            <tr>
                <td colspan="4" class="text-end"><strong>Всего продаж:</strong></td>
                <td><strong>@Model.Sum(s => s.Total).ToString("N0") ₽</strong></td>
            </tr>
        </tfoot>
    </table>
}

<div class="mt-3">
    <a asp-action="Create" class="btn btn-success">➕ Новая продажа</a>
    <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">📱 Каталог товаров</a>
</div>
