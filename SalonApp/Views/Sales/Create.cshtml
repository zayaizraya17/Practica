@using System.Collections.Generic
@using SalonApp.Models

@{
    ViewData["Title"] = "Оформить продажу";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><span class="me-2">🛒</span>Оформить продажу</h1>
    <a asp-action="Index" class="btn btn-secondary">
        <span class="me-2">↩️</span>К журналу продаж
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center">
        <span class="me-2 fs-4">✅</span>
        <div>@TempData["SuccessMessage"]</div>
    </div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card-custom">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-4">
                    <label for="productId" class="form-label">📦 Выберите товар</label>
                    
                    @{
                        var productsList = ViewBag.Products as List<Product>;
                    }

                    <select name="productId" id="productId" class="form-select form-select-lg" required onchange="updatePrice()">
                        <option value="">-- Выберите товар --</option>
                        
                        @if (productsList != null)
                        {
                            @foreach (var product in productsList)
                            {
                                <option value="@product.Id" data-price="@product.Price" data-stock="@product.Stock">
                                    @product.Name - @product.Price.ToString("N0") ₽ (остаток: @product.Stock шт.)
                                </option>
                            }
                        }
                    </select>
                    <div class="form-text">Выберите товар из списка доступных</div>
                </div>
                
                <div class="mb-4">
                    <label for="quantity" class="form-label">🔢 Количество</label>
                    <input type="number" name="quantity" id="quantity" class="form-control form-control-lg" min="1" value="1" required onchange="calculateTotal()" />
                    <div class="form-text">Укажите количество товара для продажи</div>
                </div>
                
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <label class="form-label">💵 Цена за единицу</label>
                        <input type="text" id="unitPrice" class="form-control form-control-lg bg-light" readonly value="0 ₽" />
                    </div>
                    
                    <div class="col-md-6 mb-4">
                        <label class="form-label">💰 Итоговая сумма</label>
                        <input type="text" id="totalAmount" class="form-control form-control-lg fw-bold text-success bg-light" readonly value="0 ₽" />
                    </div>
                </div>
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a asp-action="Index" class="btn btn-secondary btn-lg me-md-2">
                        <span class="me-2">❌</span>Отмена
                    </a>
                    <button type="submit" class="btn btn-success btn-lg">
                        <span class="me-2">✅</span>Оформить продажу
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card-custom">
            <h5 class="mb-3">ℹ️ Информация</h5>
            <div class="alert alert-info mb-3">
                <strong>Как оформить продажу:</strong>
                <ol class="mb-0 mt-2">
                    <li>Выберите товар</li>
                    <li>Укажите количество</li>
                    <li>Проверьте сумму</li>
                    <li>Нажмите "Оформить продажу"</li>
                </ol>
            </div>
            
            <div class="bg-light p-3 rounded">
                <h6 class="mb-2">📊 Статистика</h6>
                <p class="mb-1"><strong>Доступно товаров:</strong> @(productsList?.Count ?? 0)</p>
                <p class="mb-0"><strong>В наличии:</strong> @(productsList?.Where(p => p.Stock > 0).Count() ?? 0)</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function updatePrice() {
        var select = document.getElementById('productId');
        var selectedOption = select.options[select.selectedIndex];
        var price = selectedOption.getAttribute('data-price') || 0;
        document.getElementById('unitPrice').value = parseFloat(price).toLocaleString('ru-RU') + ' ₽';
        calculateTotal();
    }
    
    function calculateTotal() {
        var select = document.getElementById('productId');
        var selectedOption = select.options[select.selectedIndex];
        var price = parseFloat(selectedOption.getAttribute('data-price')) || 0;
        var quantity = parseInt(document.getElementById('quantity').value) || 0;
        var total = price * quantity;
        document.getElementById('totalAmount').value = total.toLocaleString('ru-RU') + ' ₽';
    }
</script>
}