@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - АИС Салон связи</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
    <div class="container mt-5">
        <h1 class="text-danger">Ошибка</h1>
        <p class="lead">Произошла ошибка при обработке вашего запроса.</p>
        @if (Model?.ShowRequestId ?? false)
        {
            <p>
                <strong>Request ID:</strong> <code>@Model?.RequestId</code>
            </p>
        }
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Вернуться в каталог</a>
    </div>
</body>
</html>
